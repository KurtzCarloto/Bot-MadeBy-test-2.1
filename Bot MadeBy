@bot.event
async def on_ready():
    await load_data()
    print(f"🚀 **BOT MADEBY** online em {len(bot.guilds)} servidores!")
    try:
        synced = await bot.tree.sync()
        print(f"✅ {len(synced)} comandos sincronizados!")
    except Exception as e:
        print(f"❌ Erro ao sincronizar: {e}")

# Tarefas automáticas
@tasks.loop(hours=1)
async def atualizar_idg():
    for nacao, data in nacoes.items():
        # Lógica simples de IDG
        data['idg'] = min(1000, data['idg'] + random.randint(-5, 15))
        data['economia']['pib'] += random.randint(50, 200)
    await save_data()

