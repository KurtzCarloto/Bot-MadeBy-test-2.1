
# bot_madeby.py
import discord
from discord.ext import commands, tasks
from discord import app_commands
import json
import os
import asyncio
import random
from datetime import datetime, timedelta
import aiofiles

# Configurações do Bot
intents = discord.Intents.default()
intents.message_content = True
intents.members = True

bot = commands.Bot(command_prefix='!', intents=intents)

# Cores oficiais MADEBY
MADEBY_COLOR = 0x1a1a2e  # Azul escuro militar
MADEBY_SUCCESS = 0x00ff88  # Verde militar
MADEBY_DANGER = 0xff4444  # Vermelho guerra
MADEBY_WARNING = 0xffaa00  # Amarelo alerta

# Arquivos de dados
DATA_DIR = "madeby_data"
os.makedirs(DATA_DIR, exist_ok=True)

# Estruturas de dados
nacoes = {}
usuarios = {}
guerras = {}
economia = {}
idg_ranking = {}
alianças = {}
militares = {}
eleicoes = {}
leis = {}
eventos = {}

# Carregar dados
async def load_data():
    global nacoes, usuarios, guerras, economia, idg_ranking, alianças, militares, eleicoes, leis, eventos
    
    files = {
        'nacoes.json': 'nacoes',
        'usuarios.json': 'usuarios',
        'guerras.json': 'guerras',
        'economia.json': 'economia',
        'idg_ranking.json': 'idg_ranking',
        'aliancas.json': 'alianças',
        'militares.json': 'militares',
        'eleicoes.json': 'eleicoes',
        'leis.json': 'leis',
        'eventos.json': 'eventos'
    }
    
    for file, var in files.items():
        try:
            async with aiofiles.open(f"{DATA_DIR}/{file}", 'r') as f:
                data = await f.read()
                globals()[var] = json.loads(data) if data else {}
        except:
            globals()[var] = {}

# Salvar dados
async def save_data():
    files = {
        'nacoes.json': nacoes,
        'usuarios.json': usuarios,
        'guerras.json': guerras,
        'economia.json': economia,
        'idg_ranking.json': idg_ranking,
        'aliancas.json': alianças,
        'militares.json': militares,
        'eleicoes.json': eleicoes,
        'leis.json': leis,
        'eventos.json': eventos
    }
    
    for file, data in files.items():
        async with aiofiles.open(f"{DATA_DIR}/{file}", 'w') as f:
            await f.write(json.dumps(data, indent=2, ensure_ascii=False))

# Embed padrão MADEBY
def madeby_embed(title, description, color=MADEBY_COLOR):
    return discord.Embed(
        title=f"👑 **MADEBY** | {title}",
        description=description,
        color=color,
        timestamp=datetime.now()
    ).set_footer(text="MadeBy Nation System | Poder pela Ordem")

# 1. SISTEMA DE NAÇÃO
@bot.tree.command(name="pais", description="Sistema de Nações")
@app_commands.describe(action="Ação do sistema de nações")
async def pais(interaction: discord.Interaction, action: str):
    user_id = str(interaction.user.id)
    
    if action == "criar":
        if user_id in usuarios:
            await interaction.response.send_message("❌ Você já tem uma nação!", ephemeral=True)
            return
            
        nome = interaction.user.display_name.replace(" ", "_").upper()
        nacoes[nome] = {
            "lider": user_id,
            "membros": [user_id],
            "economia": {"pib": 1000, "tesouro": 5000},
            "idg": 10,
            "urbanizacao": 20,
            "militar": 100,
            "criado": datetime.now().isoformat()
        }
        usuarios[user_id] = {"nacao": nome, "dinheiro": 1000, "xp": 0, "nivel": 1}
        
        embed = madeby_embed("🏛️ Nação Criada", f"**{nome}** foi fundada!\n👑 Líder: {interaction.user.mention}")
        embed.add_field(name="📊 Status Inicial", value="💰 PIB: $1.000\n💎 Tesouro: $5.000\n⚔️ IDG: 10", inline=False)
        await interaction.response.send_message(embed=embed)
    
    elif action == "info":
        if user_id not in usuarios:
            await interaction.response.send_message("❌ Crie uma nação primeiro!", ephemeral=True)
            return
            
        nacao = usuarios[user_id]["nacao"]
        data = nacoes[nacao]
        
        embed = madeby_embed(f"📊 {nacao}", f"**Estado Atual da Nação**")
        embed.add_field(name="👑 Líder", value=f"<@{data['lider']}>", inline=True)
        embed.add_field(name="👥 Membros", value=len(data['membros']), inline=True)
        embed.add_field(name="💎 PIB", value=f"${data['economia']['pib']:,.0f}", inline=True)
        embed.add_field(name="⚔️ IDG", value=data['idg'], inline=True)
        await interaction.response.send_message(embed=embed)
    
    await save_data()

# 2. SISTEMA DE GUERRA
@bot.tree.command(name="guerra", description="Sistema de Guerras")
@app_commands.describe(action="Ação da guerra")
async def guerra(interaction: discord.Interaction, action: str, alvo: discord.Member = None):
    if action == "iniciar" and alvo:
        user_id = str(interaction.user.id)
        if user_id not in usuarios:
            await interaction.response.send_message("❌ Crie uma nação primeiro!", ephemeral=True)
            return
            
        nacao_atacante = usuarios[user_id]["nacao"]
        if nacao_atacante not in nacoes:
            await interaction.response.send_message("❌ Nação não encontrada!", ephemeral=True)
            return
            
        id_alvo = str(alvo.id)
        if id_alvo not in usuarios:
            await interaction.response.send_message("❌ Alvo não tem nação!", ephemeral=True)
            return
            
        nacao_alvo = usuarios[id_alvo]["nacao"]
        
        guerra_id = f"{nacao_atacante}_vs_{nacao_alvo}_{int(datetime.now().timestamp())}"
        guerras[guerra_id] = {
            "atacante": nacao_atacante,
            "defensor": nacao_alvo,
            "status": "pendente",
            "data": datetime.now().isoformat(),
            "perdas": {"atacante": 0, "defensor": 0}
        }
        
        embed = madeby_embed("⚔️ DECLARAÇÃO DE GUERRA", f"**{nacao_atacante}** declarou guerra contra **{nacao_alvo}**!\n\n🕐 Aguardando resposta...", color=MADEBY_DANGER)
        await interaction.response.send_message(embed=embed)
    
    await save_data()

