            embed.add_field(
                name=f"{i}. {nome}",
                value=f"IDG: **{data['idg']}** | PIB: ${data['economia']['pib']:,.0f}",
                inline=False
            )
        await interaction.response.send_message(embed=embed)
    
    await save_data()

