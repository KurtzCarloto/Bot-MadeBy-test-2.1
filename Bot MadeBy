    await interaction.response.send_message(embed=embed, ephemeral=True)

@bot.tree.command(name="pagar", description="Pagar outro usuário")
@app_commands.describe(alvo="Quem receberá", valor="Valor a enviar")
async def pagar(interaction: discord.Interaction, alvo: discord.Member, valor: int):
    user_id = str(interaction.user.id)
    alvo_id = str(alvo.id)
    
    if user_id not in usuarios or alvo_id not in usuarios:
        await interaction.response.send_message("❌ Usuários inválidos!", ephemeral=True)
        return
    
    if usuarios[user_id]["dinheiro"] < valor:
        await interaction.response.send_message("❌ Saldo insuficiente!", ephemeral=True)
        return
    
    usuarios[user_id]["dinheiro"] -= valor
    usuarios[alvo_id]["dinheiro"] += valor
    
    embed = madeby_embed("💸 Transferência", f"**${valor:,.0f}** enviados para {alvo.mention}", MADEBY_SUCCESS)
    await interaction.response.send_message(embed=embed)
    await save_data()

# 4. IDG AUTOMÁTICO
@bot.tree.command(name="idg", description="Sistema IDG")
@app_commands.describe(action="Ação do IDG")
async def idg(interaction: discord.Interaction, action: str):
    if action == "ranking":
        top_nacoes = sorted(nacoes.items(), key=lambda x: x[1]['idg'], reverse=True)[:10]
        
        embed = madeby_embed("⚔️ RANKING IDG GLOBAL", "")
